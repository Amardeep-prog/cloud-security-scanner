# ──────────────────────────────────────────────────────────────────────────────
# Cloud Security Scanner — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Cloud Security Scanner"
APP_VERSION="1.0.0"
ENVIRONMENT="development"       # development | staging | production
DEBUG=true
ENABLE_DOCS=true                # Set false in production

# ── Server ────────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
WORKERS=4
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# ── AWS Credentials ───────────────────────────────────────────────────────────
# In production on EC2/ECS, leave these blank and use IAM roles instead.
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY=your_access_key_here
AWS_SECRET_KEY=your_secret_key_here
# ── S3 ────────────────────────────────────────────────────────────────────────
# ✅ FIX: was S3_BUCKET — config.py reads S3_BUCKET_NAME
S3_BUCKET_NAME="cloud-scanner-reports-123"
S3_REPORT_PREFIX="scan-reports/"
S3_PRESIGNED_URL_EXPIRY=3600    # seconds (1 hour)

# ── CloudWatch ────────────────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP="/cloud-security-scanner/app"
CLOUDWATCH_LOG_STREAM="api-events"
CLOUDWATCH_ENABLED=true

# ── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME="scan-history"
DYNAMODB_ENABLED=true

# ── Scanner ───────────────────────────────────────────────────────────────────
SCAN_TIMEOUT_SECONDS=15
BULK_SCAN_MAX_URLS=20
ASYNC_SCAN_CONCURRENCY=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_SCAN="10/minute"
RATE_LIMIT_BULK="3/minute"
RATE_LIMIT_REPORT="60/minute"

# ── API Key Auth (optional) ───────────────────────────────────────────────────
REQUIRE_API_KEY=false
API_KEYS='["your-api-key-here"]'

# ── Alerts ────────────────────────────────────────────────────────────────────
ALERT_CRITICAL_THRESHOLD=1
ALERT_SNS_TOPIC_ARN=""          # e.g. arn:aws:sns:ap-south-1:123456789:security-alerts